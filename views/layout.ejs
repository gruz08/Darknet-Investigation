<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <style>
        body {
            margin: 0;
            background: #0f172a;
            color: #e2e8f0;
            font-family: monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        main {
            width: 800px;
            background: #020617;
            border: 1px solid #334155;
            padding: 30px;
        }

        h2 {
            border-bottom: 1px solid #334155;
            padding-bottom: 10px;
        }

        input, button {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            background: #020617;
            border: 1px solid #475569;
            color: white;
        }

        button {
            cursor: pointer;
        }

        .error {
            color: #ef4444;
        }

        .ok {
            color: #22c55e;
        }
    </style>
</head>
<body>
    <main>
        <%- body %>
    </main>
</body>
</html>